{
  "name": "studious-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@testing-library/dom": "10.4.1",
    "@vitest/coverage-v8": "4.1.8",
    "jsdom": "29.1.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "dompurify": "3.4.8",
    "marked": "^18.0.5"
  },
  "overrides": {
    "vitest": {
      "vite": {
        "esbuild": "0.28.0"
      }
    }
  }
}
