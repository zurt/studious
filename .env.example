# ANTHROPIC_API_KEY is required for the default VLM provider (Anthropic Claude).
# Do NOT put it in this file. Store it in macOS Keychain and export it from
# your shell so it never touches disk in plaintext:
#
#   security add-generic-password -s ANTHROPIC_API_KEY -a "$USER" -w
#   # then in ~/.zshrc:
#   export ANTHROPIC_API_KEY="$(security find-generic-password -s ANTHROPIC_API_KEY -a "$USER" -w 2>/dev/null)"
#
# load_dotenv() does not override existing env vars, so the shell export wins.

# Where uploaded docs, page images, transcriptions, and jobs live.
# Defaults to ./data if unset.
STUDIOUS_DATA_DIR=./data

# Optional: override the path to the tesseract binary if not on PATH.
# Linux:  TESSERACT_CMD=/usr/bin/tesseract
# macOS:  TESSERACT_CMD=/opt/homebrew/bin/tesseract

# Optional: DPI used to rasterize PDF pages on upload. Default: 300.
# Higher = sharper text but larger files and slower upload (roughly quadratic).
# STUDIOUS_PDF_RENDER_DPI=300
