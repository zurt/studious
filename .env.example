# Required for the default VLM provider (Anthropic Claude)
ANTHROPIC_API_KEY=

# Where uploaded docs, page images, transcriptions, and jobs live.
# Defaults to ./data if unset.
STUDIOUS_DATA_DIR=./data

# Optional: override the path to the tesseract binary if not on PATH.
# Linux:  TESSERACT_CMD=/usr/bin/tesseract
# macOS:  TESSERACT_CMD=/opt/homebrew/bin/tesseract

# Optional: DPI used to rasterize PDF pages on upload. Default: 220.
# Higher = sharper text but larger files and slower upload (roughly quadratic).
# STUDIOUS_PDF_RENDER_DPI=220
