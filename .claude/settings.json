{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "cd backend && . .venv/bin/activate && pytest 2>&1 || true",
            "timeout": 120,
            "statusMessage": "Running tests after commit..."
          }
        ]
      }
    ]
  }
}
